{
  "compilerOptions": {
    // Target modern browsers + good WASM compatibility
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",

    // React + JSX support
    "jsx": "react-jsx",

    // Strict type checking (recommended for production)
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,

    // Module interop
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    // Output & source maps
    "noEmit": true,
    "sourceMap": true,
    "declaration": false,

    // Library support
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],

    // Base URL for clean imports
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },

  "include": [
    "src",
    "vite.config.ts"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}