{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    // Target modern JavaScript (compatible with all current browsers + Node.js)
    "target": "ES2020",
    "module": "ESNext",

    // Output settings
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    // Strict type checking (recommended for production SDKs)
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,

    // Module resolution
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,

    // Best practices for libraries
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,

    // Library and DOM support
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],

    // Do not emit files from .d.ts only (wasm-bindgen generates these)
    "noEmit": false
  },

  "include": [
    "src/index.ts"
  ],

  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts"
  ]
}